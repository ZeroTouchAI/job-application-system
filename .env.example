# Postgres connection string. Works with any Postgres host:
# Neon, Railway, Supabase-as-plain-Postgres, or local Docker.
DATABASE_URL="postgresql://user:password@localhost:5432/groundwork"

# Groq API key — used for grounded resume/cover-letter generation.
# Free tier, no credit card required: get one at https://console.groq.com
GROQ_API_KEY="gsk_..."

# Optional overrides — defaults shown. Only change these if Groq
# deprecates the default model or you want to point at a different
# OpenAI-compatible provider entirely.
# GROQ_BASE_URL="https://api.groq.com/openai/v1"
# GROQ_MODEL="openai/gpt-oss-120b"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me"
NEXTAUTH_URL="http://localhost:3000"

# Optional: comma-separated Greenhouse company board slugs to include
# in every user's job sync by default (users can add their own too).
# e.g. GREENHOUSE_DEFAULT_BOARDS="stripe,airbnb"
GREENHOUSE_DEFAULT_BOARDS=""

# Optional: comma-separated Lever company slugs, same idea.
LEVER_DEFAULT_BOARDS=""
